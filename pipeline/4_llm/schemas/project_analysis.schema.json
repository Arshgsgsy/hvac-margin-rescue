{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProjectAnalysis",
  "description": "Full analysis output from the 2-agent system (Diagnosis + Recommendation)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "project_name",
    "severity",
    "headline",
    "financial_snapshot",
    "root_causes",
    "recovery_actions",
    "forecast_if_no_action",
    "confidence"
  ],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "project_name": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["CRITICAL", "WARNING", "WATCH"]
    },
    "headline": {
      "type": "string"
    },
    "financial_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_value",
        "estimated_cost",
        "actual_cost",
        "realized_margin_pct",
        "labor_actual",
        "labor_estimated",
        "material_actual",
        "material_estimated",
        "billing_complete_pct",
        "retention_held",
        "project_stage"
      ],
      "properties": {
        "contract_value": {
          "type": ["number", "null"]
        },
        "estimated_cost": {
          "type": ["number", "null"]
        },
        "actual_cost": {
          "type": ["number", "null"]
        },
        "realized_margin_pct": {
          "type": ["number", "null"]
        },
        "labor_actual": {
          "type": ["number", "null"]
        },
        "labor_estimated": {
          "type": ["number", "null"]
        },
        "material_actual": {
          "type": ["number", "null"]
        },
        "material_estimated": {
          "type": ["number", "null"]
        },
        "billing_complete_pct": {
          "type": ["number", "null"]
        },
        "retention_held": {
          "type": ["number", "null"]
        },
        "project_stage": {
          "type": "string",
          "enum": ["early", "active", "late", "complete", "unknown"]
        }
      }
    },
    "root_causes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "category",
          "impact_dollars",
          "confidence",
          "evidence"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": ["labor", "material", "billing", "change_order", "estimate", "coordination"]
          },
          "impact_dollars": {
            "type": ["number", "null"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "counter_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "recovery_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "priority",
          "action",
          "owner",
          "financial_logic",
          "estimated_recovery_dollars",
          "urgency"
        ],
        "properties": {
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "action": {
            "type": "string"
          },
          "owner": {
            "type": "string",
            "enum": ["Project Manager", "Finance", "Operations", "Executive"]
          },
          "financial_logic": {
            "type": "string"
          },
          "estimated_recovery_dollars": {
            "type": ["number", "null"]
          },
          "urgency": {
            "type": "string",
            "enum": ["immediate", "this_week", "this_month", "ongoing"]
          },
          "linked_root_cause": {
            "type": "string",
            "description": "Label from root_causes that this action addresses"
          }
        }
      }
    },
    "forecast_if_no_action": {
      "type": "string"
    },
    "forecast_with_action": {
      "type": "string"
    },
    "total_recoverable_estimate": {
      "type": ["number", "null"]
    },
    "recoverability_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "billing_recovery_possible": {
          "type": ["boolean", "null"]
        },
        "billing_recovery_estimate": {
          "type": ["number", "null"]
        },
        "change_order_recovery_possible": {
          "type": ["boolean", "null"]
        },
        "change_order_recovery_estimate": {
          "type": ["number", "null"]
        },
        "retention_recovery_possible": {
          "type": ["boolean", "null"]
        },
        "retention_amount": {
          "type": ["number", "null"]
        },
        "remaining_margin_protection_possible": {
          "type": ["boolean", "null"]
        },
        "total_estimated_recoverable": {
          "type": ["number", "null"]
        }
      }
    },
    "missing_data": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
