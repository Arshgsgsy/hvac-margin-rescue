{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PortfolioSummary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_count",
    "severity_counts",
    "total_dollars_at_risk",
    "total_estimated_recoverable_dollars",
    "top_root_cause_patterns",
    "top_priority_projects",
    "portfolio_actions",
    "executive_summary"
  ],
  "properties": {
    "project_count": {
      "type": "integer",
      "minimum": 1
    },
    "severity_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical", "warning", "watch"],
      "properties": {
        "critical": {
          "type": "integer",
          "minimum": 0
        },
        "warning": {
          "type": "integer",
          "minimum": 0
        },
        "watch": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "total_dollars_at_risk": {
      "type": ["number", "null"]
    },
    "total_estimated_recoverable_dollars": {
      "type": ["number", "null"]
    },
    "total_retention_opportunity": {
      "type": ["number", "null"]
    },
    "top_root_cause_patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "project_count", "estimated_exposure_dollars"],
        "properties": {
          "label": {
            "type": "string"
          },
          "project_count": {
            "type": "integer",
            "minimum": 1
          },
          "estimated_exposure_dollars": {
            "type": ["number", "null"]
          }
        }
      }
    },
    "top_priority_projects": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "project_id",
          "project_name",
          "severity",
          "primary_issue",
          "estimated_recoverable_dollars"
        ],
        "properties": {
          "project_id": {
            "type": "string"
          },
          "project_name": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "WARNING", "WATCH"]
          },
          "primary_issue": {
            "type": "string"
          },
          "estimated_recoverable_dollars": {
            "type": ["number", "null"]
          }
        }
      }
    },
    "portfolio_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "owner_group", "action", "expected_impact"],
        "properties": {
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "owner_group": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "expected_impact": {
            "type": "string"
          }
        }
      }
    },
    "executive_summary": {
      "type": "string"
    }
  }
}
