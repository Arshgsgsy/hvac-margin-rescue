{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProjectAnalysis",
  "description": "Full analysis output from the 2-agent system (Diagnosis + Recommendation)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "project_name",
    "severity",
    "headline",
    "financial_snapshot",
    "root_causes",
    "recovery_actions",
    "forecast_if_no_action",
    "confidence"
  ],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "project_name": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["CRITICAL", "WARNING", "WATCH"]
    },
    "headline": {
      "type": "string"
    },
    "project_mode": {
      "type": "string",
      "enum": ["protect_margin", "accelerate_cash", "commercial_recovery", "closeout_only"]
    },
    "executive_brief": {
      "type": "string",
      "description": "Short CFO-facing recovery memo"
    },
    "financial_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_value",
        "estimated_cost",
        "actual_cost",
        "realized_margin_pct",
        "labor_actual",
        "labor_estimated",
        "material_actual",
        "material_estimated",
        "billing_complete_pct",
        "retention_held",
        "project_stage"
      ],
      "properties": {
        "contract_value": {
          "type": ["number", "null"]
        },
        "estimated_cost": {
          "type": ["number", "null"]
        },
        "actual_cost": {
          "type": ["number", "null"]
        },
        "realized_margin_pct": {
          "type": ["number", "null"]
        },
        "labor_actual": {
          "type": ["number", "null"]
        },
        "labor_estimated": {
          "type": ["number", "null"]
        },
        "material_actual": {
          "type": ["number", "null"]
        },
        "material_estimated": {
          "type": ["number", "null"]
        },
        "billing_complete_pct": {
          "type": ["number", "null"]
        },
        "retention_held": {
          "type": ["number", "null"]
        },
        "project_stage": {
          "type": "string",
          "enum": ["early", "active", "late", "complete", "unknown"]
        }
      }
    },
    "root_causes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "category",
          "impact_dollars",
          "confidence",
          "evidence"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": ["labor", "material", "billing", "change_order", "estimate", "coordination"]
          },
          "impact_dollars": {
            "type": ["number", "null"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "counter_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "recovery_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "priority",
          "action",
          "owner",
          "financial_logic",
          "estimated_recovery_dollars",
          "urgency"
        ],
        "properties": {
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "action": {
            "type": "string"
          },
          "owner": {
            "type": "string",
            "enum": ["Project Manager", "Finance", "Operations", "Executive"]
          },
          "financial_logic": {
            "type": "string"
          },
          "estimated_recovery_dollars": {
            "type": ["number", "null"]
          },
          "urgency": {
            "type": "string",
            "enum": ["immediate", "this_week", "this_month", "ongoing"]
          },
          "effort": {
            "type": "string",
            "enum": ["low", "medium", "high"],
            "description": "Effort level to execute this action"
          },
          "time_to_cash_days": {
            "type": ["integer", "null"],
            "description": "Estimated days until cash is recovered"
          },
          "linked_root_cause": {
            "type": "string",
            "description": "Label from root_causes that this action addresses"
          },
          "cost_to_execute_hours": {
            "type": ["number", "null"],
            "description": "Estimated hours to execute (low=2, medium=8, high=24)"
          },
          "expected_value": {
            "type": ["number", "null"],
            "description": "Probability-weighted recovery: estimated_recovery × confidence"
          },
          "probability_of_success": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1,
            "description": "Estimated probability that the action converts to money"
          },
          "blocking_items": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Only the concrete blockers preventing action execution"
          },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Short evidence references backing the action"
          },
          "recovery_type": {
            "type": ["string", "null"],
            "enum": ["billing", "change_order", "retention", "operational", "claim", null],
            "description": "Category of recovery for portfolio grouping"
          }
        }
      }
    },
    "primary_action": {
      "$ref": "#/properties/recovery_actions/items"
    },
    "do_not_pursue": {
      "type": "array",
      "description": "Actions that are not worth time on this project",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "reason": { "type": "string" },
              "action": { "type": "string" }
            }
          }
        ]
      }
    },
    "blocking_items": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Cross-action blockers to clear before execution"
    },
    "forecast_if_no_action": {
      "type": "string"
    },
    "forecast_with_action": {
      "type": "string"
    },
    "total_recoverable_estimate": {
      "type": ["number", "null"],
      "description": "Sum of all estimated recovery dollars across actions"
    },
    "profit_impact": {
      "type": "object",
      "description": "Before/after margin comparison showing net improvement",
      "additionalProperties": false,
      "properties": {
        "current_margin_dollars": {
          "type": ["number", "null"],
          "description": "Current margin in dollars (negative if loss)"
        },
        "projected_margin_dollars": {
          "type": ["number", "null"],
          "description": "Projected margin after recovery actions"
        },
        "net_improvement": {
          "type": ["number", "null"],
          "description": "Difference: projected - current (always show this)"
        }
      }
    },
    "recovery_by_timing": {
      "type": "object",
      "description": "Recovery amounts grouped by time horizon",
      "additionalProperties": false,
      "properties": {
        "immediate": {
          "type": ["number", "null"],
          "description": "Recoverable this week"
        },
        "near_term": {
          "type": ["number", "null"],
          "description": "Recoverable this month"
        },
        "long_term": {
          "type": ["number", "null"],
          "description": "Retention, claims, disputed COs"
        }
      }
    },
    "break_even_recovery_needed": {
      "type": ["number", "null"],
      "description": "Amount needed to recover to reach 0% margin"
    },
    "recoverability_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "billing_recovery_possible": {
          "type": ["boolean", "null"]
        },
        "billing_recovery_estimate": {
          "type": ["number", "null"]
        },
        "change_order_recovery_possible": {
          "type": ["boolean", "null"]
        },
        "change_order_recovery_estimate": {
          "type": ["number", "null"]
        },
        "retention_recovery_possible": {
          "type": ["boolean", "null"]
        },
        "retention_amount": {
          "type": ["number", "null"]
        },
        "remaining_margin_protection_possible": {
          "type": ["boolean", "null"]
        },
        "total_estimated_recoverable": {
          "type": ["number", "null"]
        }
      }
    },
    "missing_data": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
