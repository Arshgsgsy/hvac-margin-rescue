{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PortfolioOptimizationInput",
  "description": "Compressed input for the Portfolio Optimization Agent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "portfolio_stats",
    "all_actions",
    "projects_by_gc",
    "root_cause_patterns",
    "resource_capacity"
  ],
  "properties": {
    "portfolio_stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_flagged_projects",
        "severity_counts",
        "total_contract_value",
        "total_dollars_at_risk",
        "total_theoretical_recovery"
      ],
      "properties": {
        "total_flagged_projects": { "type": "integer" },
        "severity_counts": {
          "type": "object",
          "properties": {
            "critical": { "type": "integer" },
            "warning": { "type": "integer" },
            "watch": { "type": "integer" }
          }
        },
        "total_contract_value": { "type": "number" },
        "total_dollars_at_risk": { "type": "number" },
        "total_theoretical_recovery": { "type": "number" },
        "total_retention_held": { "type": ["number", "null"] },
        "total_pending_cos": { "type": ["number", "null"] },
        "total_rejected_cos": { "type": ["number", "null"] }
      }
    },
    "all_actions": {
      "type": "array",
      "description": "Flattened list of all recovery actions from all projects",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action_id",
          "project_id",
          "project_name",
          "gc_name",
          "sector",
          "project_stage",
          "action",
          "owner",
          "estimated_recovery_dollars",
          "urgency",
          "confidence"
        ],
        "properties": {
          "action_id": {
            "type": "string",
            "description": "Unique ID: project_id + priority (e.g., PRJ-2021-260_1)"
          },
          "project_id": { "type": "string" },
          "project_name": { "type": "string" },
          "gc_name": { "type": ["string", "null"] },
          "sector": { "type": ["string", "null"] },
          "project_stage": {
            "type": "string",
            "enum": ["early", "active", "late", "complete", "unknown"]
          },
          "realized_margin_pct": { "type": ["number", "null"] },
          "action": { "type": "string" },
          "owner": {
            "type": "string",
            "enum": ["Project Manager", "Finance", "Operations", "Executive"]
          },
          "financial_logic": { "type": ["string", "null"] },
          "estimated_recovery_dollars": { "type": ["number", "null"] },
          "urgency": {
            "type": "string",
            "enum": ["immediate", "this_week", "this_month", "ongoing"]
          },
          "effort": {
            "type": ["string", "null"],
            "enum": ["low", "medium", "high", null]
          },
          "time_to_cash_days": { "type": ["integer", "null"] },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "linked_root_cause": { "type": ["string", "null"] },
          "original_priority": {
            "type": "integer",
            "description": "Priority within the original project analysis"
          }
        }
      }
    },
    "projects_by_gc": {
      "type": "object",
      "description": "Projects grouped by General Contractor name",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "project_count": { "type": "integer" },
          "total_contract_value": { "type": "number" },
          "total_at_risk": { "type": "number" },
          "total_pending_cos": { "type": "number" },
          "total_rejected_cos": { "type": "number" },
          "projects": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "project_id": { "type": "string" },
                "project_name": { "type": "string" },
                "realized_margin_pct": { "type": ["number", "null"] },
                "pending_co_value": { "type": ["number", "null"] },
                "rejected_co_value": { "type": ["number", "null"] }
              }
            }
          }
        }
      }
    },
    "projects_by_sector": {
      "type": "object",
      "description": "Projects grouped by sector",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "project_count": { "type": "integer" },
          "total_at_risk": { "type": "number" },
          "avg_margin_pct": { "type": "number" },
          "common_root_causes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "root_cause_patterns": {
      "type": "array",
      "description": "Aggregated root causes sorted by frequency",
      "items": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["labor", "material", "billing", "change_order", "estimate", "coordination"]
          },
          "count": { "type": "integer" },
          "total_impact_dollars": { "type": "number" },
          "affected_projects": {
            "type": "array",
            "items": { "type": "string" }
          },
          "is_likely_systemic": { "type": "boolean" },
          "sectors_affected": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "resource_capacity": {
      "type": "object",
      "description": "Available hours per owner role this week",
      "additionalProperties": false,
      "properties": {
        "Project Manager": {
          "type": "object",
          "properties": {
            "available_hours": { "type": "number" },
            "headcount": { "type": "integer" }
          }
        },
        "Finance": {
          "type": "object",
          "properties": {
            "available_hours": { "type": "number" },
            "headcount": { "type": "integer" }
          }
        },
        "Operations": {
          "type": "object",
          "properties": {
            "available_hours": { "type": "number" },
            "headcount": { "type": "integer" }
          }
        },
        "Executive": {
          "type": "object",
          "properties": {
            "available_hours": { "type": "number" },
            "headcount": { "type": "integer" }
          }
        }
      }
    },
    "completed_project_ids": {
      "type": "array",
      "description": "Projects that are effectively complete (>95% billed)",
      "items": { "type": "string" }
    },
    "high_loss_project_ids": {
      "type": "array",
      "description": "Projects with realized margin < -50%",
      "items": { "type": "string" }
    }
  }
}
